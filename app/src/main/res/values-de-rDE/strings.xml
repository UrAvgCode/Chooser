    <string name="tutorial_welcome_title">Willkommen bei Chooser</string>
    <string name="tutorial_welcome_text">Treffe schnelle und faire Entscheidungen mit einer Berührung. Lege mehrere Finger auf den Bildschirm, warte einen kurzen Moment, und Chooser erledigt den Rest.</string>

    <string name="tutorial_how_to_use_title">So funktioniert\'s</string>
    <string name="tutorial_how_to_use_text">
    <![CDATA[
    <p>
        <b>Modus-Button</b><br/>
        Wechsle zwischen Einzel-, Gruppen- und Reihenfolgemodus.
        <b>Gedrückt halten</b>, um zusätzliche Einstellungen zu öffnen.
    </p>
    <br/>
    <p>
        <b>Zahlen-Button</b><br/>
        Lege fest, wie viele Finger ausgewählt oder wie viele Gruppen erstellt werden sollen.
    </p>
    ]]>
    </string>

    <string name="tutorial_single_mode_title">Einzelmodus</string>
    <string name="tutorial_single_mode_text">Wählt zufällig einen Finger aus allen Fingern auf dem Bildschirm aus.</string>

    <string name="tutorial_group_mode_title">Gruppenmodus</string>
    <string name="tutorial_group_mode_text">Teilt alle Finger in gleich große Teams oder Gruppen auf.</string>

    <string name="tutorial_order_mode_title">Reihenfolgemodus</string>
    <string name="tutorial_order_mode_text">Erstellt eine zufällige Reihenfolge aller Finger auf dem Bildschirm.</string>
