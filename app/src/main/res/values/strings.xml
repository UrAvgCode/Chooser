    <string name="tutorial_single_mode_title">Single Mode</string>
    <string name="tutorial_single_mode_text">Selects a random finger from all touching the screen.</string>

    <string name="tutorial_group_mode_title">Group Mode</string>
    <string name="tutorial_group_mode_text">Divides all fingers into balanced teams or groups.</string>

    <string name="tutorial_order_mode_title">Order Mode</string>
    <string name="tutorial_order_mode_text">Creates a random sequence of all fingers on screen.</string>
