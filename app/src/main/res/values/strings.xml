    <string name="tutorial_welcome_title">Welcome to Chooser</string>
    <string name="tutorial_welcome_text">Make quick, unbiased decisions with a touch. Place multiple fingers on screen, wait a brief moment, and Chooser will do the rest.</string>

    <string name="tutorial_how_to_use_title">How to Use</string>
    <string name="tutorial_how_to_use_text">
    <![CDATA[
    <p>
        <b>Mode Button</b><br/>
        Switch between Single, Group, and Order modes.
        <b>Long press</b> to access additional settings.
    </p>
    <br/>
    <p>
        <b>Number Button</b><br/>
        Adjust how many fingers to select or groups to create.
    </p>
    ]]>
